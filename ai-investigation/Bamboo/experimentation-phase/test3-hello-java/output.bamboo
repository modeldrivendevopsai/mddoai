<?xml version="1.0" encoding="ISO-8859-1"?>
<bambooMM:Plan xmi:version="2.0" xmlns:xmi="http://www.omg.org/XMI" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:bambooMM="http://www.mddoai.com/mddoai/metamodel/bamboo" projectKey="HELLO_JAVA_CI" key="HELLO_JAVA_CI" name="hello-java-ci">
  <stages name="Default Stage" jobRefs="build unitTest lintCheck"/>
  <jobs name="build" key="BUILD">
    <tasks xsi:type="bambooMM:ScriptTask">
      <scripts>gradle clean build -x test</scripts>
    </tasks>
  </jobs>
  <jobs name="unitTest" key="UNITTEST">
    <tasks xsi:type="bambooMM:ScriptTask">
      <scripts>gradle test</scripts>
    </tasks>
  </jobs>
  <jobs name="lintCheck" key="LINTCHECK">
    <tasks xsi:type="bambooMM:ScriptTask">
      <scripts>gradle check</scripts>
    </tasks>
  </jobs>
</bambooMM:Plan>
