<?xml version="1.0" encoding="ASCII"?>
<xmi:XMI xmi:version="2.0" xmlns:xmi="http://www.omg.org/XMI" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:pimMM="http://www.mddoai.com/mddoai/metamodel/pim">
  <pimMM:Pipeline name="hello-java-ci" jobStreams="build unitTest lintCheck">
    <agent xsi:type="pimMM:LinuxAgent">
      <container>
        <image xsi:type="pimMM:StringLiteral" value="gradle:jdk21"/>
      </container>
    </agent>
  </pimMM:Pipeline>
  <pimMM:ScriptJob name="build" id="build">
    <steps xsi:type="pimMM:Command">
      <program xsi:type="pimMM:StringLiteral" value="gradle clean build -x test"/>
    </steps>
  </pimMM:ScriptJob>
  <pimMM:ScriptJob name="unitTest" id="unitTest">
    <steps xsi:type="pimMM:Command">
      <program xsi:type="pimMM:StringLiteral" value="gradle test"/>
    </steps>
  </pimMM:ScriptJob>
  <pimMM:ScriptJob name="lintCheck" id="lintCheck">
    <steps xsi:type="pimMM:Command">
      <program xsi:type="pimMM:StringLiteral" value="gradle check"/>
    </steps>
  </pimMM:ScriptJob>
</xmi:XMI>
