<?xml version="1.0" encoding="ASCII"?>
<gitlabMM:Pipeline xmi:version="2.0" xmlns:xmi="http://www.omg.org/XMI" xmlns:gitlabMM="http://www.mddoai.com/mddoai/metamodel/gitlab">
  <stages>install-deps</stages>
  <stages>lint</stages>
  <stages>test-unit</stages>
  <stages>test-integration</stages>
  <stages>security-scan</stages>
  <stages>build</stages>
  <stages>docker-build</stages>
  <stages>docker-push</stages>
  <stages>deploy-staging</stages>
  <stages>e2e-test</stages>
  <stages>deploy-prod</stages>
  <workflow>
    <rules ifCondition="$CI_PIPELINE_SOURCE == &quot;push&quot;"/>
    <rules ifCondition="$CI_PIPELINE_SOURCE == &quot;merge_request_event&quot;"/>
    <rules ifCondition="$CI_PIPELINE_SOURCE == &quot;schedule&quot;"/>
  </workflow>
  <defaults timeout="90 minutes">
    <image name="docker:24-dind"/>
  </defaults>
  <variables name="REGISTRY" value="${CI_REGISTRY}"/>
  <variables name="APP_IMAGE" value="${CI_REGISTRY_IMAGE}/fullstack-webapp"/>
  <variables name="APP_VERSION" value="${CI_COMMIT_SHORT_SHA}"/>
  <jobs name="install-deps" stage="install-deps" timeout="15 minutes">
    <image name="node:20-alpine"/>
    <script>npm ci --prefer-offline</script>
    <script>cd frontend &amp;&amp; npm ci --prefer-offline</script>
    <cache>
      <key value="${CI_COMMIT_REF_SLUG}-node-modules"/>
      <paths>node_modules/</paths>
      <paths>frontend/node_modules/</paths>
    </cache>
  </jobs>
  <jobs name="lint" stage="lint">
    <image name="node:20-alpine"/>
    <script>npm run lint</script>
    <script>npm run format:check</script>
    <script>cd frontend &amp;&amp; npm run lint</script>
    <cache>
      <key value="${CI_COMMIT_REF_SLUG}-node-modules"/>
      <paths>node_modules/</paths>
      <paths>frontend/node_modules/</paths>
    </cache>
    <needs job="install-deps"/>
  </jobs>
  <jobs name="test-unit" stage="test-unit">
    <image name="node:${NODE_VERSION}-alpine"/>
    <script>npm run test:unit -- --coverage</script>
    <variables name="NODE_ENV" value="test"/>
    <variables name="CI" value="true"/>
    <artifacts name="unit-test-coverage">
      <paths>coverage/</paths>
    </artifacts>
    <cache>
      <key value="${CI_COMMIT_REF_SLUG}-node-modules"/>
      <paths>node_modules/</paths>
    </cache>
    <needs job="install-deps"/>
    <retry max="1"/>
    <parallel>
      <matrix key="NODE_VERSION">
        <values>18</values>
        <values>20</values>
        <values>22</values>
      </matrix>
    </parallel>
  </jobs>
  <jobs name="test-integration" stage="test-integration">
    <image name="node:20-alpine"/>
    <script>npm run db:migrate:test</script>
    <script>npm run test:integration</script>
    <services name="postgres:15-alpine" alias="postgres">
      <variables name="POSTGRES_DB" value="testdb"/>
      <variables name="POSTGRES_USER" value="testuser"/>
      <variables name="POSTGRES_PASSWORD" value="testpass"/>
    </services>
    <services name="redis:7-alpine" alias="redis"/>
    <variables name="DATABASE_URL" value="postgres://testuser:testpass@postgres/testdb"/>
    <variables name="REDIS_URL" value="redis://redis:6379"/>
    <artifacts name="integration-test-results">
      <paths>test-results/</paths>
    </artifacts>
    <cache>
      <key value="${CI_COMMIT_REF_SLUG}-node-modules"/>
      <paths>node_modules/</paths>
    </cache>
    <needs job="install-deps"/>
    <retry max="1"/>
  </jobs>
  <jobs name="security-scan" stage="security-scan" allowFailure="true">
    <image name="node:20-alpine"/>
    <script>snyk/actions/node@master</script>
    <script>npm audit --audit-level=critical</script>
    <variables name="SNYK_TOKEN" value="${SNYK_TOKEN}"/>
    <artifacts name="security-report">
      <paths>snyk-report.sarif</paths>
    </artifacts>
    <needs job="install-deps"/>
  </jobs>
  <jobs name="build" stage="build">
    <image name="node:20-alpine"/>
    <script>npm run build:backend</script>
    <script>cd frontend &amp;&amp; npm run build</script>
    <variables name="NODE_ENV" value="production"/>
    <artifacts name="build-output">
      <paths>dist/</paths>
      <paths>frontend/dist/</paths>
    </artifacts>
    <cache>
      <key value="${CI_COMMIT_REF_SLUG}-node-modules"/>
      <paths>node_modules/</paths>
      <paths>frontend/node_modules/</paths>
    </cache>
    <needs job="lint"/>
    <needs job="test-unit"/>
    <needs job="test-integration"/>
  </jobs>
  <jobs name="docker-build" stage="docker-build">
    <image name="docker:24-dind"/>
    <script>docker login -u ${CI_REGISTRY_USER} -p ${CI_JOB_TOKEN} ${REGISTRY}</script>
    <script>docker build --build-arg APP_VERSION=${APP_VERSION} -t ${APP_IMAGE}:${APP_VERSION} -t ${APP_IMAGE}:latest .</script>
    <script># conditional step: ${CI_COMMIT_BRANCH} == 'main'</script>
    <variables name="DOCKER_BUILDKIT" value="1"/>
    <needs job="build"/>
  </jobs>
  <jobs name="docker-push" stage="docker-push">
    <image name="docker:24-dind"/>
    <script>docker login -u ${CI_REGISTRY_USER} -p ${CI_JOB_TOKEN} ${REGISTRY}</script>
    <script>docker push ${APP_IMAGE}:${APP_VERSION}</script>
    <script>docker push ${APP_IMAGE}:latest</script>
    <script># conditional step: ${CI_COMMIT_BRANCH} == 'main'</script>
    <needs job="docker-build"/>
    <needs job="security-scan"/>
  </jobs>
  <jobs name="deploy-staging" stage="deploy-staging" timeout="20 minutes">
    <image name="bitnami/kubectl:latest"/>
    <script>kubectl config use-context staging</script>
    <script>kubectl set image deployment/webapp app=${APP_IMAGE}:${APP_VERSION} -n staging</script>
    <script>kubectl rollout status deployment/webapp -n staging --timeout=5m</script>
    <variables name="KUBECONFIG" value="${STAGING_KUBECONFIG}"/>
    <variables name="DEPLOY_NAMESPACE" value="staging"/>
    <needs job="docker-push"/>
  </jobs>
  <jobs name="e2e-test" stage="e2e-test" allowFailure="false">
    <image name="mcr.microsoft.com/playwright:v1.44.0-jammy"/>
    <script>npm run test:e2e -- --reporter=html</script>
    <variables name="BASE_URL" value="https://staging.example.com"/>
    <variables name="CI" value="true"/>
    <artifacts name="e2e-report">
      <paths>playwright-report/</paths>
      <paths>test-results/</paths>
    </artifacts>
    <needs job="deploy-staging"/>
    <rules ifCondition="${SKIP_E2E} != 'true'"/>
    <retry max="1"/>
  </jobs>
  <jobs name="deploy-prod" stage="deploy-prod" allowFailure="false" timeout="30 minutes">
    <image name="bitnami/kubectl:latest"/>
    <script>kubectl config use-context production</script>
    <script>kubectl set image deployment/webapp app=${APP_IMAGE}:${APP_VERSION} -n production</script>
    <script>kubectl rollout status deployment/webapp -n production --timeout=10m</script>
    <script># conditional step: ${CI_COMMIT_TAG} != ''</script>
    <variables name="KUBECONFIG" value="${PROD_KUBECONFIG}"/>
    <variables name="DEPLOY_NAMESPACE" value="production"/>
    <needs job="e2e-test"/>
    <rules ifCondition="${CI_COMMIT_BRANCH} == 'main' || ${CI_COMMIT_TAG} != ''"/>
  </jobs>
</gitlabMM:Pipeline>
