<?xml version="1.0" encoding="ISO-8859-1"?>
<azuredevopsMM:Pipeline xmi:version="2.0" xmlns:xmi="http://www.omg.org/XMI" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:azuredevopsMM="http://www.mddoai.com/mddoai/metamodel/azuredevops" name="chatbot-app">
  <variables xsi:type="azuredevopsMM:VariableName" name="IMAGE_NAME" value="${CI_REGISTRY_IMAGE}/framework-chatbot-image"/>
  <variables xsi:type="azuredevopsMM:VariableName" name="IMAGE_TAG" value="${IMAGE_NAME}:${IMAGE_VERSION}-${CI_COMMIT_REF_SLUG}"/>
  <pool vmImage="ubuntu-latest"/>
  <jobs xsi:type="azuredevopsMM:Job" job="build" displayName="build">
    <steps xsi:type="azuredevopsMM:ScriptStep" script="docker build -t ${IMAGE_TAG} ."/>
  </jobs>
  <jobs xsi:type="azuredevopsMM:Job" job="unitTest" displayName="unitTest">
    <pool vmImage="ubuntu-latest"/>
    <container xsi:type="azuredevopsMM:ContainerImage" image="python:3.12-slim"/>
    <steps xsi:type="azuredevopsMM:ScriptStep" script="python3 test/run_unit_tests.py"/>
  </jobs>
  <jobs xsi:type="azuredevopsMM:Job" job="healthCheck" displayName="healthCheck">
    <dependsOn>build</dependsOn>
    <pool vmImage="ubuntu-latest"/>
    <container xsi:type="azuredevopsMM:ContainerImage" image="curlimages/curl:latest"/>
    <steps xsi:type="azuredevopsMM:ScriptStep" script="./scripts/health_check.sh"/>
  </jobs>
  <jobs xsi:type="azuredevopsMM:Job" job="push" displayName="push">
    <dependsOn>healthCheck</dependsOn>
    <steps xsi:type="azuredevopsMM:ScriptStep" script="docker login -u ${CI_REGISTRY_USER} -p ${CI_JOB_TOKEN} ${CI_REGISTRY}"/>
    <steps xsi:type="azuredevopsMM:ScriptStep" script="docker push ${IMAGE_TAG}"/>
  </jobs>
</azuredevopsMM:Pipeline>
