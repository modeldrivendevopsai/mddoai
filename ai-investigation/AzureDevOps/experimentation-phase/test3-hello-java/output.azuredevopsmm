<?xml version="1.0" encoding="ISO-8859-1"?>
<azuredevopsMM:Pipeline xmi:version="2.0" xmlns:xmi="http://www.omg.org/XMI" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:azuredevopsMM="http://www.mddoai.com/mddoai/metamodel/azuredevops" name="hello-java-ci">
  <pool vmImage="ubuntu-latest"/>
  <jobs xsi:type="azuredevopsMM:Job" job="build" displayName="build">
    <steps xsi:type="azuredevopsMM:ScriptStep" script="gradle clean build -x test"/>
  </jobs>
  <jobs xsi:type="azuredevopsMM:Job" job="unitTest" displayName="unitTest">
    <steps xsi:type="azuredevopsMM:ScriptStep" script="gradle test"/>
  </jobs>
  <jobs xsi:type="azuredevopsMM:Job" job="lintCheck" displayName="lintCheck">
    <steps xsi:type="azuredevopsMM:ScriptStep" script="gradle check"/>
  </jobs>
</azuredevopsMM:Pipeline>
