# Where ai-layer's shared /chat endpoint is reachable, used for link-selection
# and content-cleanup LLM calls.
#
# docker-compose.yml sets this to http://ai-layer:8000 (the service name) for
# the retrieval container, Docker's internal DNS resolves that, localhost
# would not. Only override this if running retrieval outside Docker, e.g.
# `uvicorn main:app --reload` directly against a host-based ai-layer:
AI_LAYER_URL=http://localhost:8000

# Every other tuning value (page/link budgets, timeouts, cache sizes, content
# filter thresholds, etc.) is also environment-variable-overridable; see the
# constant definitions at the top of retrieval.py and main.py for the full
# list of names and current defaults. None are required, all fall back to a
# value already tuned against real sites.
