# Free-tier providers (all optional — missing keys are skipped silently)
GOOGLE_API_KEY=
MISTRAL_API_KEY=
CEREBRAS_API_KEY=
GROQ_API_KEY=

# Claude Pro/Max subscription — alternative to ANTHROPIC_API_KEY with no extra API cost
# Run `claude setup-token` once, copy the printed token, and paste it below.
# Gives access to claude-haiku-4-5 using your existing Claude Pro/Max subscription.
# This token is tried BEFORE the commercial ANTHROPIC_API_KEY entry.
CLAUDE_CODE_OAUTH_TOKEN=

# Commercial fallback (used only when all free providers are exhausted)
ANTHROPIC_API_KEY=
