# Free-tier providers (all optional — missing keys are skipped silently)
GOOGLE_API_KEY=
MISTRAL_API_KEY=
CEREBRAS_API_KEY=
GROQ_API_KEY=

# Claude Pro/Max subscription — alternative to ANTHROPIC_API_KEY with no extra API cost.
# The router tries this BEFORE the commercial ANTHROPIC_API_KEY entry.
#
# Option A — manual setup (any environment):
#   Run `claude setup-token` once, copy the printed token, paste it here.
#
# Option B — auto-detect (if you have run `claude login` on this machine):
#   Leave this blank. The router automatically reads the token from
#   ~/.claude/.credentials.json (written by `claude login`). That token is
#   short-lived (~60 min) and is only read once at startup — restart the
#   process if it starts failing auth after a while. Prefer Option A for a
#   long-running server.
#
# Either way, gives access to claude-haiku-4-5 at no additional API cost.
CLAUDE_CODE_OAUTH_TOKEN=

# Commercial fallback (used only when all free providers are exhausted)
ANTHROPIC_API_KEY=
