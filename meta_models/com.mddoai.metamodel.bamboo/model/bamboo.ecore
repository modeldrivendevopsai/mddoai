    <eStructuralFeatures xsi:type="ecore:EReference" name="branchConfig" upperBound="-1" eType="#//VariableAssignment" containment="true"/>
  </eClassifiers>

  <eClassifiers xsi:type="ecore:EClass" name="ChangeDetection">
