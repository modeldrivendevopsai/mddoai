<<mxfile host="app.diagrams.net">
  <diagram name="Orchestrator" id="orchestrator-diagram">
    <mxGraphModel dx="1400" dy="800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1100" pageHeight="900" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <mxCell id="chat" value="Chat Interface" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="40" y="40" width="160" height="50" as="geometry" />
        </mxCell>

        <mxCell id="orch" value="Orchestrator" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="1">
          <mxGeometry x="260" y="40" width="160" height="50" as="geometry" />
        </mxCell>

        <mxCell id="e1" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;" edge="1" parent="1" source="chat" target="orch">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <mxCell id="psmGroup" value="PSM stage" style="rounded=1;whiteSpace=wrap;html=1;verticalAlign=top;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1">
          <mxGeometry x="40" y="140" width="640" height="280" as="geometry" />
        </mxCell>

        <mxCell id="run" value="Run PSM agent" style="rounded=1;whiteSpace=wrap;html=1;" vertex="1" parent="1">
          <mxGeometry x="70" y="190" width="150" height="50" as="geometry" />
        </mxCell>

        <mxCell id="check" value="Automated check" style="rounded=1;whiteSpace=wrap;html=1;" vertex="1" parent="1">
          <mxGeometry x="270" y="190" width="150" height="50" as="geometry" />
        </mxCell>

        <mxCell id="show" value="Show result to human" style="rounded=1;whiteSpace=wrap;html=1;" vertex="1" parent="1">
          <mxGeometry x="470" y="190" width="170" height="50" as="geometry" />
        </mxCell>

        <mxCell id="e2" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;" edge="1" parent="1" source="run" target="check">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e3" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;" edge="1" parent="1" source="check" target="show">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <mxCell id="output" value="Output / advance to next stage" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="1">
          <mxGeometry x="470" y="320" width="170" height="60" as="geometry" />
        </mxCell>

        <mxCell id="curate" value="Human curates the prompt directly" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;" vertex="1" parent="1">
          <mxGeometry x="70" y="320" width="170" height="60" as="geometry" />
        </mxCell>

        <mxCell id="e4" value="approved" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;exitX=0.5;exitY=1;entryX=0.5;entryY=0;" edge="1" parent="1" source="show" target="output">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e5" value="not approved" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;exitX=0.5;exitY=1;entryX=0.5;entryY=1;" edge="1" parent="1" source="show" target="curate">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="555" y="420" />
              <mxPoint x="155" y="420" />
            </Array>
          </mxGeometry>
        </mxCell>
        <mxCell id="e6" value="rerun same stage" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;exitX=0.5;exitY=0;entryX=0.5;entryY=1;" edge="1" parent="1" source="curate" target="run">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <mxCell id="atl" value="ATL agent&#10;(same review loop as PSM)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;" vertex="1" parent="1">
          <mxGeometry x="40" y="460" width="220" height="60" as="geometry" />
        </mxCell>

        <mxCell id="acceleo" value="Acceleo agent&#10;(same review loop as PSM)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;" vertex="1" parent="1">
          <mxGeometry x="300" y="460" width="220" height="60" as="geometry" />
        </mxCell>

        <mxCell id="gen" value="Generation + Integration Test&#10;(same review loop as PSM)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;" vertex="1" parent="1">
          <mxGeometry x="40" y="550" width="480" height="60" as="geometry" />
        </mxCell>

        <mxCell id="e7" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;" edge="1" parent="1" source="output" target="atl">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e8" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;" edge="1" parent="1" source="atl" target="acceleo">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e9" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;" edge="1" parent="1" source="acceleo" target="gen">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <mxCell id="e10" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;" edge="1" parent="1" source="gen" target="chat">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="900" y="580" />
              <mxPoint x="900" y="65" />
            </Array>
          </mxGeometry>
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
