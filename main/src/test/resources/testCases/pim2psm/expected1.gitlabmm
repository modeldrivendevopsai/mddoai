<?xml version="1.0" encoding="ISO-8859-1"?>
<gitlabMM:Pipeline xmi:version="2.0" xmlns:xmi="http://www.omg.org/XMI" xmlns:gitlabMM="http://www.mddoai.com/mddoai/metamodel/gitlab">
  <stages>build</stages>
  <stages>unitTest</stages>
  <stages>healthCheck</stages>
  <stages>push</stages>
  <defaults>
    <image name="docker:latest"/>
  </defaults>
  <variables name="IMAGE_NAME" value="${CI_REGISTRY_IMAGE}/framework-chatbot-image"/>
  <variables name="IMAGE_TAG" value="${IMAGE_NAME}:${IMAGE_VERSION}-${CI_COMMIT_REF_SLUG}"/>
  <jobs name="build" stage="build">
    <script>docker build -t ${IMAGE_TAG} .</script>
  </jobs>
  <jobs name="unitTest" stage="unitTest">
    <image name="python:3.12-slim"/>
    <script>python3 test/run_unit_tests.py</script>
  </jobs>
  <jobs name="healthCheck" stage="healthCheck">
    <image name="curlimages/curl:latest"/>
    <script>./scripts/health_check.sh</script>
    <needs job="build"/>
  </jobs>
  <jobs name="push" stage="push">
    <script>docker login -u ${CI_REGISTRY_USER} -p ${CI_JOB_TOKEN} ${CI_REGISTRY}</script>
    <script>docker push ${IMAGE_TAG}</script>
    <needs job="healthCheck"/>
  </jobs>
</gitlabMM:Pipeline>
